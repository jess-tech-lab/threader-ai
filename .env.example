# =============================================================================
# Threader AI — Environment Variables
# Copy this file to .env and fill in your credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (required)
# Used for subreddit discovery, feedback classification, and strategic synthesis.
# Get your key at https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Supabase (optional - required for database persistence and report sharing)
# Create a free project at https://supabase.com then find the following keys in 
# Project Settings -> API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Frontend (Vite) — mirrors of the Supabase vars above for the React.js app
# These must start with VITE_ to be exposed to the browser bundle.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Reddit scraping uses public RSS feeds — no API credentials required.
